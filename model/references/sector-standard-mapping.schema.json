{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ondtf.example/schema/sector-standard-mapping.schema.json",
  "title": "ONDTF Sector-Standard Mapping",
  "type": "object",
  "required": ["sector_id", "version", "status", "authority", "standards"],
  "properties": {
    "sector_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"enum": ["illustrative", "draft", "candidate", "approved", "retired"]},
    "authority": {"type": "string", "minLength": 1},
    "standards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["standard_id", "disposition", "adoption_mode", "selected_scope", "rationale", "evidence_required", "review"],
        "properties": {
          "standard_id": {"type": "string"},
          "disposition": {"enum": ["discovered", "mapped", "candidate", "adopted", "retired"]},
          "adoption_mode": {"enum": ["informative-reference", "capability-adoption", "partial-normative-adoption", "normative-profile-dependency"]},
          "relevance": {"type": "array", "items": {"type": "string"}},
          "selected_scope": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "excluded_scope": {"type": "array", "items": {"type": "string"}},
          "rationale": {"type": "string", "minLength": 20},
          "evidence_required": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "conflicts": {"type": "array", "items": {"type": "string"}},
          "review": {
            "type": "object",
            "required": ["owner", "triggers"],
            "properties": {
              "owner": {"type": "string", "minLength": 1},
              "next_review": {"type": ["string", "null"], "format": "date"},
              "triggers": {"type": "array", "minItems": 1, "items": {"type": "string"}}
            }
          }
        }
      }
    }
  }
}
