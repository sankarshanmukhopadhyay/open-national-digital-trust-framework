{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ondtf.example/schema/requirement-catalogue.json",
  "title": "ONDTF normative requirement catalogue",
  "type": "object",
  "required": ["specification", "version", "status", "requirements"],
  "properties": {
    "specification": {"const": "ONDTF"},
    "version": {"type": "string"},
    "status": {"enum": ["draft", "active", "deprecated", "withdrawn"]},
    "requirements": {
      "type": "array",
      "items": {"$ref": "#/$defs/requirement"}
    }
  },
  "$defs": {
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "domain", "force", "statement", "applicability", "assessed_object", "accountable_role", "responsible_roles", "evidence", "status", "introduced"],
      "properties": {
        "id": {"type": "string", "pattern": "^ONDTF-[A-Z]{3}-[0-9]{3}$"},
        "domain": {"type": "string"},
        "force": {"enum": ["MUST", "MUST_NOT", "SHOULD", "SHOULD_NOT", "MAY"]},
        "statement": {"type": "string", "minLength": 15},
        "applicability": {"type": "array", "minItems": 1, "items": {"enum": ["core", "institutional", "scheme", "provider", "service", "implementation", "interaction", "affected-party", "profile"]}},
        "assessed_object": {"type": "string"},
        "condition": {"type": "string"},
        "accountable_role": {"type": "string", "pattern": "^ROLE-[A-Z]{2,5}$"},
        "responsible_roles": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^ROLE-[A-Z]{2,5}$"}},
        "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "capabilities": {"type": "array", "items": {"type": "string"}},
        "principles": {"type": "array", "items": {"type": "string"}},
        "source": {"type": "string"},
        "status": {"enum": ["draft", "active", "deprecated", "withdrawn", "superseded"]},
        "introduced": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "supersedes": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
