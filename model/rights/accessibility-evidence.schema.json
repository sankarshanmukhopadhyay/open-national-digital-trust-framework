{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ONDTF Accessibility Evidence",
  "type": "object",
  "required": [
    "record_id",
    "profile_id",
    "created_at",
    "journey",
    "methods",
    "findings",
    "status"
  ],
  "properties": {
    "record_id": {
      "type": "string"
    },
    "profile_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "journey": {
      "type": "string"
    },
    "methods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "participant_characteristics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "barriers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "remediation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
