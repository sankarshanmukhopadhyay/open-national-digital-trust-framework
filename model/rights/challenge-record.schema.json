{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ONDTF Challenge Record",
  "type": "object",
  "required": [
    "record_id",
    "profile_id",
    "affected_party_reference",
    "created_at",
    "grounds",
    "status"
  ],
  "properties": {
    "record_id": {
      "type": "string"
    },
    "profile_id": {
      "type": "string"
    },
    "affected_party_reference": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string"
    },
    "grounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "challenged_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "interim_protection": {
      "type": "string"
    },
    "responsible_role": {
      "type": "string"
    },
    "outcome": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
