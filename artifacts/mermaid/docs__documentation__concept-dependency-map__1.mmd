flowchart LR
  ACT[Actor and participant] --> ID[Identity and role]
  ID --> AUTH[Authority]
  AUTH --> DEL[Delegation]
  DEL --> CRED[Credential and evidence]
  CRED --> POL[Policy and duties]
  POL --> ASS[Assurance]
  ASS --> DEC[Decision]
  DEC --> EFF[Effect]
  EFF --> REC[Receipt and audit]
  REC --> CH[Challenge]
  CH --> REM[Remedy]
  REM --> GOV[Governance learning]
  GOV --> POL
